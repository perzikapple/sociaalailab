# Environment Variables Template
# Copy to your server and fill in with actual values
# Do NOT commit the actual .env file with passwords to version control

# Email Configuration (Brevo SMTP)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USERNAME=your_brevo_email@example.com
EMAIL_PASSWORD=your_brevo_smtp_key_here
EMAIL_FROM=noreply@sociaalailab.nl

# Database (if needed)
# DB_HOST=localhost
# DB_NAME=sociaalai
# DB_USER=root
# DB_PASS=your_password
